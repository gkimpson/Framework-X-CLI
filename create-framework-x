#!/usr/bin/env bash
set -e

if [ $# -ne 1 ]; then
    echo "Usage: create-framework-x <project-name>"
    exit 1
fi

PROJECT="$1"

if ! command -v php &> /dev/null; then
    echo "Error: php not found. Install PHP first."
    exit 1
fi

if ! command -v composer &> /dev/null; then
    echo "Error: composer not found. Install Composer first."
    echo "See: https://getcomposer.org/download/"
    exit 1
fi

if [ -d "$PROJECT" ]; then
    echo "Error: directory '$PROJECT' already exists."
    exit 1
fi

mkdir "$PROJECT"
cd "$PROJECT"

echo "Creating Framework-X project: $PROJECT"
echo ""

cat > composer.json << 'EOF'
{
    "require": {
        "clue/framework-x": "^0.17"
    },
    "require-dev": {
        "phpunit/phpunit": "^11"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    }
}
EOF

composer install

mkdir -p public src tests

cat > .gitignore << 'EOF'
/vendor/
/.env
EOF

cat > public/index.php << 'EOF'
<?php

require __DIR__ . '/../vendor/autoload.php';

$app = new FrameworkX\App();

$app->get('/', App\HelloController::class);
$app->get('/users/{name}', App\UserController::class);

$app->run();
EOF

cat > src/HelloController.php << 'EOF'
<?php

namespace App;

use React\Http\Message\Response;

class HelloController
{
    public function __invoke(): Response
    {
        return Response::plaintext("Hello wörld!\n");
    }
}
EOF

cat > src/UserController.php << 'EOF'
<?php

namespace App;

use Psr\Http\Message\ServerRequestInterface;
use React\Http\Message\Response;

class UserController
{
    public function __invoke(ServerRequestInterface $request): Response
    {
        return Response::plaintext(
            "Hello " . $request->getAttribute('name') . "!\n"
        );
    }
}
EOF

cat > tests/HelloControllerTest.php << 'EOF'
<?php

namespace App\Tests;

use App\HelloController;
use PHPUnit\Framework\TestCase;
use Psr\Http\Message\ResponseInterface;

class HelloControllerTest extends TestCase
{
    public function testReturnsPlaintextHello(): void
    {
        $response = (new HelloController())();

        $this->assertInstanceOf(ResponseInterface::class, $response);
        $this->assertSame(200, $response->getStatusCode());
        $this->assertSame("Hello wörld!\n", (string) $response->getBody());
    }
}
EOF

cat > tests/UserControllerTest.php << 'EOF'
<?php

namespace App\Tests;

use App\UserController;
use PHPUnit\Framework\TestCase;
use Psr\Http\Message\ResponseInterface;
use React\Http\Message\ServerRequest;

class UserControllerTest extends TestCase
{
    public function testReturnsPlaintextWithName(): void
    {
        $request = (new ServerRequest('GET', 'http://localhost/users/Alice'))
            ->withAttribute('name', 'Alice');

        $response = (new UserController())($request);

        $this->assertInstanceOf(ResponseInterface::class, $response);
        $this->assertSame(200, $response->getStatusCode());
        $this->assertSame("Hello Alice!\n", (string) $response->getBody());
    }
}
EOF

cat > phpunit.xml << 'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true">
    <testsuites>
        <testsuite name="Application Test Suite">
            <directory>tests</directory>
        </testsuite>
    </testsuites>
</phpunit>
EOF

echo ""
echo "Project '$PROJECT' created successfully!"
echo ""
echo "Running tests..."
echo ""

vendor/bin/phpunit

echo ""
echo "Starting dev server at http://localhost:8000"
echo "Press Ctrl+C to stop."
echo ""

php -S localhost:8000 -t public/
